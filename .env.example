# Server (use development on your PC; production on Railway/hosting)
NODE_ENV=development
PORT=5000

# --- MongoDB (must start with mongodb:// or mongodb+srv://) ---

# Local (default for dev):
MONGODB_URI=mongodb://127.0.0.1:27017/team-task-manager

# Atlas (replace USER, PASS, cluster host — URL-encode special chars in password):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/team-task-manager?retryWrites=true&w=majority

# If SRV DNS fails (querySrv ECONNREFUSED), use Atlas "Compass" standard URI here instead:
# MONGODB_URI_DIRECT=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/team-task-manager?ssl=true&replicaSet=...

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS + httpOnly cookies: must match the URL in the browser address bar (no trailing slash).
# Comma-separated if you have multiple (e.g. Vercel prod + preview):
CLIENT_URL=http://localhost:5173

# Optional: public URL of this app (helps CORS on Railway if CLIENT_URL was wrong)
# PUBLIC_APP_URL=https://team-task-manager-production-xxxx.up.railway.app

# Optional: extra allowed origins (Vercel previews, second frontend)
# CORS_ORIGINS=https://my-app-git-preview.vercel.app

# When frontend and API are on different domains (Vercel + Railway), production uses
# SameSite=None cookies — deploy API with HTTPS (Railway/Vercel both OK).
